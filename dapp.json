{
  "name": "PuzzleChain",
  "secrets": [
    {
      "key": "VALIDATOR_PRIVATE_KEY",
      "description": "ECDSA private key for the validator wallet that signs claimWin messages. Staging default is Hardhat account #0.",
      "required": true,
      "private": true,
      "staging_default": "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
    },
    {
      "key": "UTGO_CONTRACT_ADDRESS",
      "description": "Deployed WagerEscrow contract address on Usernode EVM chain. Staging uses a placeholder (no real contract).",
      "required": false,
      "private": false,
      "staging_default": "0x0000000000000000000000000000000000000001"
    },
    {
      "key": "TREASURY_WALLET",
      "description": "EVM address receiving the 8% treasury cut of each wager pot.",
      "required": false,
      "private": false,
      "staging_default": "0x0000000000000000000000000000000000000002"
    },
    {
      "key": "REDIS_URL",
      "description": "Optional Redis connection URL used only as a fast path for the PvP matchmaking queue and match timers. The app fully degrades to its built-in Postgres CAS queue when unset, so this is not required to deploy.",
      "required": false,
      "private": false,
      "staging_default": "redis://localhost:6379"
    },
    {
      "key": "APP_PUBKEY",
      "description": "Public app-identity key that identifies PuzzleChain to the Usernode dApps-integration surface; returned alongside HMAC-signed integration payloads so callers can attribute them to this app. Public (non-secret); set the production value in Settings → Secrets. Staging uses a well-known Hardhat account #1 address.",
      "required": true,
      "private": false,
      "staging_default": "0x70997970C51812dc3A010C7d01b50e0d17dc79C8"
    },
    {
      "key": "APP_SECRET_KEY",
      "description": "Secret app-identity key used to HMAC-sign payloads PuzzleChain sends to the Usernode dApps-integration surface; an empty value disables the integration gracefully. Treated as an opaque HMAC key (any format works). Set the production value in Settings → Secrets. Staging uses a dummy (Hardhat account #1 key).",
      "required": true,
      "private": true,
      "staging_default": "0x2a871d0798f97d308287f1bd8254e4e96cecc5f0cfa1d93fcff5fb3f87f81947"
    }
  ],
  "tests": [
    { "name": "Main screen loads with no console errors", "path": "/", "expectText": "PuzzleChain" },
    { "name": "Lobby renders", "path": "/", "expectText": "PuzzleChain" },
    { "name": "Locked card after daily attempt", "path": "/?demo=locked", "expectText": "resets in" },
    { "name": "Word Hunt card in lobby", "path": "/", "expectText": "Word Hunt" },
    { "name": "Crypto Wordle card in lobby", "path": "/", "expectText": "Crypto Wordle" },
    { "name": "Lobby shows live reset countdown", "path": "/", "expectText": "Next puzzle in" },
    { "name": "Streak multiplier hint in lobby", "path": "/?demo=streak", "expectText": "day streak" },
    { "name": "Leaderboard seed boots cleanly", "path": "/?demo=leaderboard", "expectText": "Daily Puzzles" },
    { "name": "In-progress resume card in lobby", "path": "/?demo=resume", "expectText": "In progress" },
    { "name": "Power-up demo seeds successfully", "path": "/?demo=powerup", "expectText": "PuzzleChain" },
    { "name": "Minesweeper card in Classic Games tab", "path": "/?tab=classic", "expectText": "Minesweeper" },
    { "name": "Mancala card in Classic Games tab", "path": "/?tab=classic", "expectText": "Mancala" },
    { "name": "2048 card in Classic Games tab", "path": "/?tab=classic", "expectText": "2048" },
    { "name": "Snake card in Classic Games tab", "path": "/?tab=classic", "expectText": "Snake" },
    { "name": "Block Blast card in Classic Games tab", "path": "/?tab=classic", "expectText": "Block Blast" },
    { "name": "Tile Match Puzzle card in Classic Games tab", "path": "/?tab=classic", "expectText": "Tile Match Puzzle" },
    { "name": "Match-3 Puzzle card in Classic Games tab", "path": "/?tab=classic", "expectText": "Match-3 Puzzle" },
    { "name": "Diamond Rush card in Classic Games tab", "path": "/?tab=classic", "expectText": "Diamond Rush" },
    { "name": "Texas Hold Em card in Classic Games tab", "path": "/?tab=classic", "expectText": "Texas Hold 'Em" },
    { "name": "Bounce card in Classic Games tab", "path": "/?tab=classic", "expectText": "Bounce" },
    { "name": "Zuma card in Classic Games tab", "path": "/?tab=classic", "expectText": "Zuma" },
    { "name": "Daily Tile Match Puzzle card in lobby", "path": "/", "expectText": "Daily Tile Match Puzzle" },
    { "name": "Idle Empire in Idle Empire tab", "path": "/?tab=idle", "expectText": "Idle Empire" },
    { "name": "Idle game loads with demo data", "path": "/?tab=idle&demo=progress", "expectText": "Coins" },
    { "name": "PvP Arena tab renders", "path": "/?tab=pvp", "expectText": "PvP Arena" },
    { "name": "Wallet screen shows pending rewards", "path": "/?screen=wallet&demo=1", "expectText": "Pending Rewards" },
    { "name": "Hash Rush card in Classic Games tab", "path": "/?tab=classic", "expectText": "Hash Rush" },
    { "name": "Boots with dApps integration disabled (empty APP_SECRET_KEY)", "path": "/", "expectText": "PuzzleChain" },
    { "name": "Wallet shows Verified identity badge", "path": "/?screen=wallet&demo=1", "expectText": "Verified identity" },
    { "name": "Wallet shows Disconnect control", "path": "/?screen=wallet&demo=1", "expectText": "Disconnect" },
    { "name": "DApp session receipt renders", "path": "/?demo=dapp", "expectText": "Session Receipt" },
    { "name": "DApp receipt shows chain hash", "path": "/?demo=dapp", "expectText": "Chain hash" },
    { "name": "Verified leaderboard renders demo rows", "path": "/?demo=dapp", "expectText": "Staging demo Ada" },
    { "name": "Disputed session shows rejection copy", "path": "/?screen=session&sid=DAPPDEMOBAD", "expectText": "could not be verified" },
    { "name": "Account screen opens from chip", "path": "/?screen=account", "expectText": "On-chain login" },
    { "name": "Account screen shows account heading", "path": "/?screen=account", "expectText": "Account" }
  ]
}
